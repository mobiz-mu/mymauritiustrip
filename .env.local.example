# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. NEVER expose to the browser. Used for privileged server jobs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Cloudinary (public listing media) ----
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---- Resend (email; SMTP fallback optional) ----
RESEND_API_KEY=your-resend-key
EMAIL_FROM="MyMauritiusTrip <info@mymauritiustrip.com>"
# Admin gets notified of new bookings/verifications/etc.
ADMIN_NOTIFICATION_EMAIL=admin@mymauritiustrip.com

# ---- Cron (commission reminders) ----
# Required for the daily reminder job. On Vercel, set this in Project env and the
# platform automatically sends `Authorization: Bearer <CRON_SECRET>` on cron calls.
# If unset, the endpoint refuses to run (so it's never publicly triggerable).
CRON_SECRET=generate-a-long-random-string

# ---- Support contacts (used across the app) ----
NEXT_PUBLIC_SUPPORT_WHATSAPP=+23055068119
NEXT_PUBLIC_SUPPORT_EMAIL=info@mymauritiustrip.com

# ---- Analytics (optional; site builds/runs fine if unset) ----
# Google Tag Manager container id, e.g. GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
# Google Analytics 4 measurement id, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
